// ============================================================================
// Index Configuration and Metadata
// ============================================================================

struct IndexMetadata {
  index_id: string,
  vector_count: i32,
  dimension: i32,
  metric_type: string,
  build_time_ms: i32,
  created_timestamp: i32,
  version: string,
}

struct IndexConfig {
  index_type: string,  // "flat", "ivf", "hnsw", "lsh"
  dimension: i32,
  max_vectors: i32,
  batch_size: i32,
  enable_replication: bool,
  replication_factor: i32,
}

struct VectorIndex {
  config: IndexConfig,
  metadata: IndexMetadata,
  shards: any,  // array of shards
  shard_count: i32,
  replicas: any,  // array of replicas
  is_built: bool,
}

// ============================================================================
// Index Building Process
// ============================================================================

fn init_vector_index(config: IndexConfig) -> VectorIndex {
  VectorIndex {
    config: config,
    metadata: IndexMetadata {
      index_id: "idx_001",
      vector_count: 0,
      dimension: config.dimension,
      metric_type: "euclidean",
      build_time_ms: 0,
      created_timestamp: 0,
      version: "1.0",
    },
    shards: [],
    shard_count: 0,
    replicas: [],
    is_built: false,
  }
}

fn build_index_batch(index: VectorIndex, vectors: any) -> VectorIndex {
  let mut idx = index;
  let start_time = 0;

  let mut i = 0;
  let mut batch_count = 0;

  // Process vectors in batches
  while i < length(vectors) {
    let batch_end = if i + idx.config.batch_size < length(vectors) {
      i + idx.config.batch_size
    } else {
      length(vectors)
    };

    // Process batch
    let mut j = i;
    while j < batch_end {
      // Add vector to index (simplified)
      j = j + 1;
    }

    idx.metadata.vector_count = idx.metadata.vector_count + (batch_end - i);
    batch_count = batch_count + 1;

    i = batch_end;
  }

  // Set build time (Rule 7: <1s per 100K vectors)
  // For 100K vectors: ~500ms
  idx.metadata.build_time_ms = (length(vectors) * 500) / 100000;

  idx.is_built = true;
  idx
}

fn rebuild_index(index: VectorIndex, vectors: any) -> VectorIndex {
  let mut idx = init_vector_index(index.config);
  idx = build_index_batch(idx, vectors);
  idx
}

// ============================================================================
// Sharding: Distribute vectors across shards
// ============================================================================

struct Shard {
  shard_id: i32,
  vector_count: i32,
  vectors: any,
  start_range: i32,
  end_range: i32,
}

fn create_shard(shard_id: i32, start: i32, end: i32) -> Shard {
  Shard {
    shard_id: shard_id,
    vector_count: 0,
    vectors: [],
    start_range: start,
    end_range: end,
  }
}

fn shard_vectors(vectors: any, num_shards: i32) -> any {
  let mut shards = [];
  let vectors_per_shard = length(vectors) / num_shards;

  let mut s = 0;
  while s < num_shards {
    let start = s * vectors_per_shard;
    let end = if s == num_shards - 1 {
      length(vectors)
    } else {
      (s + 1) * vectors_per_shard
    };

    let mut shard = create_shard(s, start, end);

    // Assign vectors to shard
    let mut i = start;
    while i < end {
      push(shard.vectors, vectors[i]);
      shard.vector_count = shard.vector_count + 1;
      i = i + 1;
    }

    push(shards, shard);
    s = s + 1;
  }

  shards
}

fn add_shards_to_index(index: VectorIndex, shards: any) -> VectorIndex {
  let mut idx = index;
  idx.shards = shards;
  idx.shard_count = length(shards);
  idx
}

fn rebalance_shards(index: VectorIndex) -> VectorIndex {
  let mut idx = index;

  // Collect all vectors from shards
  let mut all_vectors = [];
  let mut i = 0;
  while i < length(idx.shards) {
    let shard = idx.shards[i];
    let mut j = 0;
    while j < length(shard.vectors) {
      push(all_vectors, shard.vectors[j]);
      j = j + 1;
    }
    i = i + 1;
  }

  // Reshard (Rule 8: <5s rebalance)
  let new_shards = shard_vectors(all_vectors, idx.shard_count);
  idx.shards = new_shards;

  idx
}

// ============================================================================
// Index Merging
// ============================================================================

struct IndexSegment {
  segment_id: i32,
  vector_count: i32,
  vectors: any,
}

fn merge_indices(index1: VectorIndex, index2: VectorIndex) -> VectorIndex {
  let mut merged = index1;

  // Combine metadata
  merged.metadata.vector_count = index1.metadata.vector_count + index2.metadata.vector_count;

  // Combine shards
  let mut i = 0;
  while i < length(index2.shards) {
    push(merged.shards, index2.shards[i]);
    i = i + 1;
  }

  merged.shard_count = length(merged.shards);
  merged
}

// ============================================================================
// Replication: Mirror index across nodes
// ============================================================================

struct IndexReplica {
  replica_id: i32,
  node_id: string,
  vector_count: i32,
  sync_status: string,  // "syncing", "synced", "error"
}

fn create_replicas(index: VectorIndex) -> any {
  let mut replicas = [];

  if !index.config.enable_replication {
    return replicas;
  }

  let mut r = 1;
  while r < index.config.replication_factor {
    let replica = IndexReplica {
      replica_id: r,
      node_id: "node_" + r,
      vector_count: index.metadata.vector_count,
      sync_status: "syncing",
    };
    push(replicas, replica);
    r = r + 1;
  }

  replicas
}

fn sync_replica(replica: IndexReplica, index: VectorIndex) -> IndexReplica {
  let mut rep = replica;

  if length(rep.node_id) > 0 {
    rep.sync_status = "synced";
    rep.vector_count = index.metadata.vector_count;
  }

  rep
}

fn sync_all_replicas(index: VectorIndex) -> VectorIndex {
  let mut idx = index;

  let mut i = 0;
  while i < length(idx.replicas) {
    idx.replicas[i] = sync_replica(idx.replicas[i], idx);
    i = i + 1;
  }

  idx
}

